# Copy this file to .env and fill in your values
# Example: cp .env.example .env

# Discord webhook URL (required)
# Get this from your Discord server settings > Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Filter time window in hours (default: 24)
FILTER_HOURS=24

# Keyword filter (comma-separated, optional)
# Only entries matching these keywords will be sent
KEYWORDS=Kotlin,Compose,Android,Coroutine,KMP

# Custom feeds (optional, format: "name:url;name2:url2")
# If not set, uses default feeds (Kotlin Blog, Android Developers)
# FEEDS=MyBlog:https://example.com/feed.xml;AnotherBlog:https://other.com/atom.xml
